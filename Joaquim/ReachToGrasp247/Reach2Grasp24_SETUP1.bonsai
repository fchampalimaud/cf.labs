            <Expression xsi:type="rx:BehaviorSubject">
              <Name>WaterROIThresh</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>Pos</Name>
            </Expression>
            <Expression xsi:type="scr:ExpressionTransform">
              <scr:Expression>Convert.ToString(it)</scr:Expression>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>BoxNb</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:Zip" />
            </Expression>
            <Expression xsi:type="ipy:PythonTransform">
              <ipy:Script>dico1 = {'1950':286,
        '1900':310,
        '1850':311,
        '1800':322,
        '1750':334,
        '1700':348,
        '1650':362,
        '1600':376,
        '1550':386,
        '1500':400,
        '1450':414}


dico2 = {'1950':272,
        '1900':286,
        '1850':300,
        '1800':314,
        '1750':328,
        '1700':342,
        '1650':356,
        '1600':368,
        '1550':383,
        '1500':396,
        '1450':410}

def process(value):
  if value.Item2 == 1:
    return dico1[value.Item1]
  elif value.Item2 == 2:
    return dico2[value.Item1]
  </ipy:Script>
            </Expression>
            <Expression xsi:type="rx:BehaviorSubject">
              <Name>WaterROIPosX</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>BoxNb</Name>
            </Expression>
            <Expression xsi:type="ipy:PythonTransform">
              <ipy:Script>

def process(value) :
  if value== 1:
    return 62
  elif value == 2:
    return 80
  </ipy:Script>
            </Expression>
