              <ipy:Script>@returns(int)


def process(value):

  dico1 = {'1950':286,
          '1900':299,
          '1850':311,
          '1800':322,
          '1750':334,
          '1700':348,
          '1650':362,
          '1600':376,
          '1550':386,
          '1500':400,
          '1450':414}

  dico2 = {'1950':272,
          '1900':286,
          '1850':300,
          '1800':314,
          '1750':328,
          '1700':342,
          '1650':356,
          '1600':368,
          '1550':383,
          '1500':396,
          '1450':410}

  if value.Item1 == 1:
    return dico1[value.Item2]-20
  elif value.Item1 == 2:
    return dico2[value.Item2]-20
  </ipy:Script>
