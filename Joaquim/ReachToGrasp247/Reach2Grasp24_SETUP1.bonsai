            <Expression xsi:type="ipy:PythonTransform">
              <ipy:Script>dico1 = {'1950':284,
        '1900':300,
        '1850':311,
        '1800':324,
        '1750':337,
        '1700':350,
        '1650':364,
        '1600':378,
        '1550':390,
        '1500':407,
        '1450':417}

dico2 = {'1950':272,
        '1900':286,
        '1850':300,
        '1800':314,
        '1750':328,
        '1700':342,
        '1650':356,
        '1600':368,
        '1550':383,
        '1500':396,
        '1450':410}


def process(value):
  if value.Item2 == 1:
    return dico1[value.Item1]
  elif value.Item2 == 2:
    return dico2[value.Item1]
  </ipy:Script>
