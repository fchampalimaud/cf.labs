<?xml version="1.0" encoding="utf-8"?>
<WorkflowBuilder Version="2.9.0"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xmlns:rx="clr-namespace:Bonsai.Reactive;assembly=Bonsai.Core"
                 xmlns:beh="clr-namespace:Harp.Behavior;assembly=Harp.Behavior"
                 xmlns:harp="clr-namespace:Bonsai.Harp;assembly=Bonsai.Harp"
                 xmlns:scr="clr-namespace:Bonsai.Scripting.Expressions;assembly=Bonsai.Scripting.Expressions"
                 xmlns:ipy="clr-namespace:Bonsai.Scripting.IronPython;assembly=Bonsai.Scripting.IronPython"
                 xmlns:p1="clr-namespace:Harp.RfidReader;assembly=Harp.RfidReader"
                 xmlns:wie="clr-namespace:Bonsai.Windows.Input;assembly=Bonsai.Windows.Input"
                 xmlns:pump="clr-namespace:Harp.SyringePump;assembly=Harp.SyringePump"
                 xmlns:io="clr-namespace:Bonsai.IO;assembly=Bonsai.System"
                 xmlns:cv="clr-namespace:Bonsai.Vision;assembly=Bonsai.Vision"
                 xmlns:spk="clr-namespace:Bonsai.Spinnaker;assembly=Bonsai.Spinnaker"
                 xmlns:dsp="clr-namespace:Bonsai.Dsp;assembly=Bonsai.Dsp"
                 xmlns:gui="clr-namespace:Bonsai.Gui;assembly=Bonsai.Gui"
                 xmlns:p2="clr-namespace:Bonsai.Harp.CF;assembly=Bonsai.Harp.CF"
                 xmlns="https://bonsai-rx.org/2018/workflow">
  <Workflow>
    <Nodes>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="rx:Timer">
          <rx:DueTime>PT0S</rx:DueTime>
          <rx:Period>PT1M</rx:Period>
        </Combinator>
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="rx:Delay">
          <rx:DueTime>PT2S</rx:DueTime>
        </Combinator>
      </Expression>
      <Expression xsi:type="rx:BehaviorSubject">
        <Name>MinutesInSession</Name>
      </Expression>
      <Expression xsi:type="SubscribeSubject">
        <Name>DurationSession</Name>
      </Expression>
      <Expression xsi:type="PropertyMapping">
        <PropertyMappings>
          <Property Name="DueTime" />
        </PropertyMappings>
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="rx:Timer">
          <rx:DueTime>PT2H40M</rx:DueTime>
        </Combinator>
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="rx:Delay">
          <rx:DueTime>PT2S</rx:DueTime>
        </Combinator>
      </Expression>
      <Expression xsi:type="beh:CreateMessage">
        <harp:MessageType>Write</harp:MessageType>
        <harp:Payload xsi:type="beh:CreateStopCamerasPayload">
          <beh:StopCameras>CameraOutput0</beh:StopCameras>
        </harp:Payload>
      </Expression>
      <Expression xsi:type="MulticastSubject">
        <Name>BehaviorCommands</Name>
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="rx:Delay">
          <rx:DueTime>PT10S</rx:DueTime>
        </Combinator>
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="rx:Take">
          <rx:Count>1</rx:Count>
        </Combinator>
      </Expression>
      <Expression xsi:type="WorkflowOutput" />
      <Expression xsi:type="Annotation">
        <Name>Shortcuts</Name>
        <Text><![CDATA[Right Arrow: Move water servo away from RC
Left Arrow: Move water servo towards the RC
F: Filling up syringe
R: Single reward
A/S: Lock control 
L/K: Open and close slider door
]]></Text>
      </Expression>
      <Expression xsi:type="GroupWorkflow">
        <Name>Init</Name>
        <Workflow>
          <Nodes>
            <Expression xsi:type="GroupWorkflow">
              <Name>SetFilenames</Name>
              <Workflow>
                <Nodes>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>PATH</Name>
                  </Expression>
                  <Expression xsi:type="Add">
                    <Operand xsi:type="StringProperty">
                      <Value>Behavior\behavior_data.bin</Value>
                    </Operand>
                  </Expression>
                  <Expression xsi:type="rx:BehaviorSubject">
                    <Name>BehaviorDataFile</Name>
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>PATH</Name>
                  </Expression>
                  <Expression xsi:type="Add">
                    <Operand xsi:type="StringProperty">
                      <Value>ROI_Water.csv</Value>
                    </Operand>
                  </Expression>
                  <Expression xsi:type="rx:BehaviorSubject">
                    <Name>ROIWaterFile</Name>
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>PATH</Name>
                  </Expression>
                  <Expression xsi:type="Add">
                    <Operand xsi:type="StringProperty">
                      <Value>ROI_Reach.csv</Value>
                    </Operand>
                  </Expression>
                  <Expression xsi:type="rx:BehaviorSubject">
                    <Name>ROIReachFile</Name>
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>PATH</Name>
                  </Expression>
                  <Expression xsi:type="Add">
                    <Operand xsi:type="StringProperty">
                      <Value>AllFramesIDList.csv</Value>
                    </Operand>
                  </Expression>
                  <Expression xsi:type="rx:BehaviorSubject">
                    <Name>AllFramesFile</Name>
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>PATH</Name>
                  </Expression>
                  <Expression xsi:type="Add">
                    <Operand xsi:type="StringProperty">
                      <Value>pump.csv</Value>
                    </Operand>
                  </Expression>
                  <Expression xsi:type="rx:BehaviorSubject">
                    <Name>PumpFile</Name>
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>PATH</Name>
                  </Expression>
                  <Expression xsi:type="Add">
                    <Operand xsi:type="StringProperty">
                      <Value>Performance.csv</Value>
                    </Operand>
                  </Expression>
                  <Expression xsi:type="rx:BehaviorSubject">
                    <Name>PerformanceFile</Name>
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>PATH</Name>
                  </Expression>
                  <Expression xsi:type="Add">
                    <Operand xsi:type="StringProperty">
                      <Value>Behavior\device.yml</Value>
                    </Operand>
                  </Expression>
                  <Expression xsi:type="rx:BehaviorSubject">
                    <Name>BehaviorConfigFile</Name>
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>PATH</Name>
                  </Expression>
                  <Expression xsi:type="Add">
                    <Operand xsi:type="StringProperty">
                      <Value>FrameClip_.csv</Value>
                    </Operand>
                  </Expression>
                  <Expression xsi:type="rx:BehaviorSubject">
                    <Name>FrameClipFile</Name>
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>PATH</Name>
                  </Expression>
                  <Expression xsi:type="Add">
                    <Operand xsi:type="StringProperty">
                      <Value>Clip_.avi</Value>
                    </Operand>
                  </Expression>
                  <Expression xsi:type="rx:BehaviorSubject">
                    <Name>ClipFile</Name>
                  </Expression>
                </Nodes>
                <Edges>
                  <Edge From="0" To="1" Label="Source1" />
                  <Edge From="1" To="2" Label="Source1" />
                  <Edge From="3" To="4" Label="Source1" />
                  <Edge From="4" To="5" Label="Source1" />
                  <Edge From="6" To="7" Label="Source1" />
                  <Edge From="7" To="8" Label="Source1" />
                  <Edge From="9" To="10" Label="Source1" />
                  <Edge From="10" To="11" Label="Source1" />
                  <Edge From="12" To="13" Label="Source1" />
                  <Edge From="13" To="14" Label="Source1" />
                  <Edge From="15" To="16" Label="Source1" />
                  <Edge From="16" To="17" Label="Source1" />
                  <Edge From="18" To="19" Label="Source1" />
                  <Edge From="19" To="20" Label="Source1" />
                  <Edge From="21" To="22" Label="Source1" />
                  <Edge From="22" To="23" Label="Source1" />
                  <Edge From="24" To="25" Label="Source1" />
                  <Edge From="25" To="26" Label="Source1" />
                </Edges>
              </Workflow>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="IntProperty">
                <Value>0</Value>
              </Combinator>
            </Expression>
            <Expression xsi:type="rx:BehaviorSubject">
              <Name>Counter</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="IntProperty">
                <Value>0</Value>
              </Combinator>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:IgnoreElements" />
            </Expression>
            <Expression xsi:type="rx:BehaviorSubject">
              <Name>PumpActivation</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="BooleanProperty">
                <Value>false</Value>
              </Combinator>
            </Expression>
            <Expression xsi:type="rx:PublishSubject">
              <Name>Start_Clip</Name>
            </Expression>
            <Expression xsi:type="rx:BehaviorSubject">
              <Name>UseFillProtocol</Name>
            </Expression>
            <Expression xsi:type="ExternalizedMapping">
              <Property Name="Value" DisplayName="Path" />
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="StringProperty">
                <Value>C:\Users\hgmar\Desktop\Joaquim\ReachToGrasp247\data\</Value>
              </Combinator>
            </Expression>
            <Expression xsi:type="rx:BehaviorSubject">
              <Name>PATH</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="IntProperty">
                <Value>0</Value>
              </Combinator>
            </Expression>
            <Expression xsi:type="rx:BehaviorSubject">
              <Name>CountActivations</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="BooleanProperty">
                <Value>false</Value>
              </Combinator>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:Skip">
                <rx:Count>1</rx:Count>
              </Combinator>
            </Expression>
            <Expression xsi:type="rx:BehaviorSubject">
              <Name>ActivateServos</Name>
            </Expression>
            <Expression xsi:type="rx:BehaviorSubject">
              <Name>ActivateServosSlider</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="BooleanProperty">
                <Value>false</Value>
              </Combinator>
            </Expression>
            <Expression xsi:type="rx:PublishSubject">
              <Name>Attempt</Name>
            </Expression>
            <Expression xsi:type="ExternalizedMapping">
              <Property Name="Value" DisplayName="pos_init" />
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="IntProperty">
                <Value>1900</Value>
              </Combinator>
            </Expression>
            <Expression xsi:type="rx:BehaviorSubject">
              <Name>Pos</Name>
            </Expression>
            <Expression xsi:type="ExternalizedMapping">
              <Property Name="Value" DisplayName="BoxNb" />
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="IntProperty">
                <Value>1</Value>
              </Combinator>
            </Expression>
            <Expression xsi:type="rx:BehaviorSubject">
              <Name>BoxNb</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>Pos</Name>
            </Expression>
            <Expression xsi:type="scr:ExpressionTransform">
              <scr:Expression>Convert.ToString(it)</scr:Expression>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>BoxNb</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:Zip" />
            </Expression>
            <Expression xsi:type="ipy:PythonTransform">
              <ipy:Script>dico1 = {'1950':286,
        '1900':299,
        '1850':311,
        '1800':322,
        '1750':334,
        '1700':348,
        '1650':362,
        '1600':376,
        '1550':386,
        '1500':400,
        '1450':414}

dico2 = {'1950':272,
        '1900':286,
        '1850':300,
        '1800':314,
        '1750':328,
        '1700':342,
        '1650':356,
        '1600':368,
        '1550':383,
        '1500':396,
        '1450':410}


def process(value):
  if value.Item1 == 1:
    return dico1[value.Item2]-20
  elif value.Item1 == 2:
    return dico2[value.Item2]-20
  </ipy:Script>
            </Expression>
            <Expression xsi:type="rx:BehaviorSubject">
              <Name>ReahROIPosX</Name>
            </Expression>
            <Expression xsi:type="ipy:PythonTransform">
              <ipy:Script>
def process(value):
  dico1 = {'1950':71,
          '1900':70,
          '1850':69,
          '1800':68,
          '1750':67,
          '1700':57,
          '1650':57,
          '1600':55,
          '1550':55,
          '1500':62,
          '1450':61}

  dico2 = {'1950':75,
          '1900':74,
          '1850':74,
          '1800':73,
          '1750':61,
          '1700':61,
          '1650':62,
          '1600':60,
          '1550':65,
          '1500':68,
          '1450':67}

  if value.Item2 == 1:
    return dico1[value.Item1]+2
  elif value.Item2 == 2:

    return dico2[value.Item1]+2
  </ipy:Script>
            </Expression>
            <Expression xsi:type="PropertyMapping">
              <PropertyMappings>
                <Property Name="Value" Selector="it" />
              </PropertyMappings>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="IntProperty">
                <Value>72</Value>
              </Combinator>
