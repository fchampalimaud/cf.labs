      <Expression xsi:type="GroupWorkflow">
        <Name>RFID</Name>
        <Workflow>
          <Nodes>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:Timer">
                <rx:DueTime>PT0.2S</rx:DueTime>
                <rx:Period>PT0.2S</rx:Period>
              </Combinator>
            </Expression>
            <Expression xsi:type="harp:CreateMessage">
              <harp:MessageType>Write</harp:MessageType>
              <harp:Payload xsi:type="harp:CreateMessagePayload">
                <harp:Address>43</harp:Address>
                <harp:PayloadType>U8</harp:PayloadType>
                <harp:Value>1</harp:Value>
              </harp:Payload>
            </Expression>
            <Expression xsi:type="p1:CreateMessage">
              <harp:MessageType>Write</harp:MessageType>
              <harp:Payload xsi:type="p1:CreateHardwareNotificationsStatePayload">
                <p1:HardwareNotificationsState>BottomLed</p1:HardwareNotificationsState>
              </harp:Payload>
            </Expression>
            <Expression xsi:type="harp:CreateMessage">
              <harp:MessageType>Write</harp:MessageType>
              <harp:Payload xsi:type="harp:CreateMessagePayload">
                <harp:Address>43</harp:Address>
                <harp:PayloadType>U8</harp:PayloadType>
                <harp:Value>1</harp:Value>
              </harp:Payload>
