              <ipy:Script>import clr  # For pythonnet

# Add a reference to the System.Windows.Forms assembly
clr.AddReference('System.Windows.Forms')

import System
def process(value):
  if value == 1:
    return System.Windows.Forms.Keys.Q
  elif value == 2:
    return System.Windows.Forms.Keys.W</ipy:Script>
